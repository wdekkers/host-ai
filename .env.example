DATABASE_URL=postgres://walt:walt@localhost:5432/walt
PORT=3000

# Hospitable integration (inbound + outbound)
# Inbound webhook signature verification. If unset, signature checks are skipped.
HOSPITABLE_WEBHOOK_SECRET=replace-with-your-hospitable-webhook-secret
# Outbound/provider auth placeholders for future API client implementation.
HOSPITABLE_API_KEY=replace-with-your-hospitable-api-key
HOSPITABLE_BASE_URL=https://api.hospitable.com
