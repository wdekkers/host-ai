# Copy to apps/web/.env.local for local Next.js runtime.
# Values can also be set from the repo-root .env.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_replace_me
CLERK_SECRET_KEY=sk_test_replace_me

HOSPITABLE_API_KEY=replace-with-your-hospitable-api-key
HOSPITABLE_BASE_URL=https://api.hospitable.com
ANTHROPIC_API_KEY=sk-ant-replace-me

# Internal service URLs (server-side only)
GATEWAY_URL=http://localhost:3001
MESSAGING_SERVICE_URL=http://localhost:3002

# Twilio — used by /api/twilio/inbound to validate webhook signatures
TWILIO_AUTH_TOKEN=replace-me
