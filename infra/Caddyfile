{
	email admin@walt-services.com
}

ai.walt-services.com {
	# Next.js API routes (integrations, auth callbacks, etc.)
	handle /api/integrations/* {
		reverse_proxy web:3000
	}

	# API Gateway
	handle /api/* {
		reverse_proxy gateway:4000
	}

	# Swagger docs
	handle /docs* {
		reverse_proxy gateway:4000
	}

	# Next.js web dashboard (catch-all)
	handle {
		reverse_proxy web:3000
	}

	log {
		output stdout
		format console
	}

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}
}
