{
	email admin@walt-services.com
}

palmera-frisco.com, dreamscapefrisco.com, friscowavesandfairways.com {
	reverse_proxy sites:3001

	log {
		output stdout
		format console
	}

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}
}

ai.walt-services.com {
	# API Gateway routes only
	handle /api/health* {
		reverse_proxy gateway:4000
	}

	handle /api/me* {
		reverse_proxy gateway:4000
	}

	# Swagger docs
	handle /docs* {
		reverse_proxy gateway:4000
	}

	# All other /api/* routes go to Next.js (command-center, integrations, etc.)
	handle /api/* {
		reverse_proxy web:3000
	}

	# Next.js web dashboard (catch-all)
	handle {
		reverse_proxy web:3000
	}

	log {
		output stdout
		format console
	}

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		-Server
	}
}
