# ──────────────────────────────────────────
# Lightsail Managed PostgreSQL
# ──────────────────────────────────────────
DATABASE_URL=postgres://walt:CHANGEME@ls-xxxxx.us-east-1.rds.amazonaws.com:5432/walt?sslmode=require

# ──────────────────────────────────────────
# Hospitable Integration
# ──────────────────────────────────────────
HOSPITABLE_WEBHOOK_SECRET=replace-with-production-value
HOSPITABLE_API_KEY=replace-with-production-value
HOSPITABLE_BASE_URL=https://api.hospitable.com

# ──────────────────────────────────────────
# Docker image tag (optional, defaults to latest)
# ──────────────────────────────────────────
IMAGE_TAG=latest
