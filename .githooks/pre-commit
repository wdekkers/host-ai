#!/bin/sh
set -eu

echo "Running pre-commit checks: lint, typecheck, prettier"

pnpm lint
pnpm typecheck

STAGED_PRETTIER_FILES="$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|js|jsx|mjs|cjs|json|md|css|yml|yaml)$' || true)"
if [ -n "$STAGED_PRETTIER_FILES" ]; then
  echo "$STAGED_PRETTIER_FILES" | xargs pnpm exec prettier --check
else
  echo "No staged files matched prettier extensions."
fi
